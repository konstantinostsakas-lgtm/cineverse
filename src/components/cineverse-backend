// Real-time synchronization server core handler (Socket.io)
io.on('connection', (socket) => {
  
  // 1. Είσοδος χρήστη σε συγκεκριμένο live δωμάτιο ταινίας
  socket.on('join-room', (roomId) => {
    if (roomId) {
      socket.join(roomId);
    }
  });

  // 2. Real-time συγχρονισμός του video player (Play / Pause / Seek) μεταξύ των χρηστών
  socket.on('video-control', ({ roomId, action, currentTime }) => {
    if (roomId && action) {
      socket.to(roomId).emit('video-control-client', { 
        action, 
        currentTime: currentTime || 0 
      });
    }
  });

  // 3. Άμεση προώθηση πραγματικών μηνυμάτων συνομιλίας (Live Chat Stream)
  socket.on('send-message', ({ roomId, message }) => {
    if (roomId && message) {
      socket.to(roomId).emit('receive-message', message);
    }
  });

});